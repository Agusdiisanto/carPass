# Hardhat / Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
DEPLOYER_PRIVATE_KEY=0xyour_private_key_without_quotes
ETHERSCAN_API_KEY=your_etherscan_api_key_optional
CARPASS_CONTRACT_ADDRESS=
# Direccion de VehicleParts. Si esta vacia, los scripts usan deployments/sepolia/VehicleParts.json.
VEHICLEPARTS_CONTRACT_ADDRESS=
# Direccion de CarPassOracle. Si esta vacia, los scripts usan deployments/sepolia/CarPassOracle.json.
CARPASS_ORACLE_CONTRACT_ADDRESS=
# Wallet que recibira REGISTRADOR_ROLE (alta de vehiculos). Usar con npm run grant:registrador:sepolia
GRANT_TARGET_WALLET=

# Frontend
VITE_SEPOLIA_CHAIN_ID=11155111
VITE_SEPOLIA_RPC_URL=
VITE_CARPASS_PUBLIC_READ_TIMEOUT_MS=4500
# Optional override. If empty, frontend can use exported deployments/sepolia/CarPass.json.
VITE_CARPASS_CONTRACT_ADDRESS=
# Optional override. If empty, frontend can use exported deployments/sepolia/VehicleParts.json.
VITE_VEHICLEPARTS_CONTRACT_ADDRESS=
# Optional override. If empty, frontend can use exported deployments/sepolia/CarPassOracle.json.
VITE_CARPASS_ORACLE_CONTRACT_ADDRESS=
# Bloque Sepolia desde el cual leer logs Transfer (mejora sync del garaje). Ejemplo: 11175893
VITE_CARPASS_DEPLOY_BLOCK=
