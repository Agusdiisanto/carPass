VITE_SEPOLIA_CHAIN_ID=11155111
# RPC publico para lecturas sin wallet (opcional; hay fallback publico).
VITE_SEPOLIA_RPC_URL=
# Timeout de lectura publica live antes de usar snapshot/demo.
VITE_CARPASS_PUBLIC_READ_TIMEOUT_MS=4500
# Optional override. If empty, frontend can use exported deployment artifacts.
VITE_CARPASS_CONTRACT_ADDRESS=
# URL publica del deploy (Vercel, etc.). Requerida para Phone Companion, deep link MetaMask mobile y QR Connect desde localhost.
VITE_PUBLIC_APP_URL=
# IP LAN manual si la autodeteccion falla (ej. 192.168.0.155). Misma WiFi que el celular.
VITE_DEV_LAN_HOST=
